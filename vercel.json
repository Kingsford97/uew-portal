{
  "builds": [
    {
      "src": "uew_portal/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.10"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/media/(.*)",
      "dest": "/media/$1"
    },
    {
      "src": "/(.*)",
      "dest": "uew_portal/wsgi.py"
    }
  ],
  "env": {
    "ALLOWED_HOSTS": ".vercel.app",
    "DEBUG": "False",
    "PYTHON_VERSION": "3.10"
  }
}